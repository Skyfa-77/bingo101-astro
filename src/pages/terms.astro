---
// src/pages/terms.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import brand from '../config/brand.js';
import content from '../content/brand-text.json';

const data = {
    ...brand,
    ...content,
};
---

<BaseLayout seo={{
    title: "Terms of Service — Bingo 101",
    description: "Read our Terms of Service to understand the rules and guidelines for using our platform.",
    canonical: "https://bingo101-astro.hachimura77.workers.dev/terms",
    ogImage: "/images/og-default.jpg",
}} themeColor={data.pwa.themeColor}>

    <div class="container">
        <h1>Terms of Service</h1>
        <p><em>Last updated: July 2026</em></p>

        <h2>Acceptance of Terms</h2>
        <p>By using our website and services, you agree to be bound by these Terms of Service. If you do not agree, please do not use our site.</p>

        <h2>Description of Service</h2>
        <p>This website provides informational reviews and guides about Bingo 101. We do not offer gambling services, accept bets, or process financial transactions.</p>

        <h2>User Responsibilities</h2>
        <p>You agree to use our site only for lawful purposes and in a way that does not infringe the rights of others. You are responsible for maintaining the confidentiality of your account information.</p>

        <h2>Intellectual Property</h2>
        <p>All content on this site, including text, graphics, logos, and images, is the property of Bingo 101 Review or its content suppliers and is protected by copyright laws.</p>

        <h2>Disclaimer of Warranties</h2>
        <p>Our site is provided on an "as is" and "as available" basis. We make no warranties, expressed or implied, regarding the accuracy, reliability, or availability of our site.</p>

        <h2>Limitation of Liability</h2>
        <p>In no event shall Bingo 101 Review be liable for any direct, indirect, incidental, special, or consequential damages arising out of or in connection with your use of our site.</p>

        <h2>Changes to Terms</h2>
        <p>We reserve the right to update these Terms of Service at any time. Your continued use of the site after changes constitutes acceptance of the new terms.</p>

        <h2>Contact Us</h2>
        <p>If you have any questions about these Terms, please contact us at: <a href="mailto:legal@bingo101.com">legal@bingo101.com</a></p>
    </div>

    <style is:global>
        .container h1 {
            font-size: 32px;
            margin-bottom: 16px;
        }
        .container h2 {
            font-size: 24px;
            margin-top: 32px;
            margin-bottom: 12px;
            border-bottom: 1px solid #333;
            padding-bottom: 8px;
        }
        .container p {
            margin-bottom: 16px;
            line-height: 1.8;
        }
        .container a {
            color: #44b357;
        }
    </style>
</BaseLayout>